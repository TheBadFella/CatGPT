# CatGPT Gateway configuration
# Copy to .env and adjust as needed.

# Provider: "chatgpt" or "claude"
PROVIDER=chatgpt

# Browser
BROWSER_DATA_DIR=./browser_data
HEADLESS=false
SLOW_MO=50

# Provider URLs
CHATGPT_URL=https://chatgpt.com
CLAUDE_URL=https://claude.ai

# ChatGPT model switching. Leave CHATGPT_DEFAULT_MODEL empty to use the
# currently selected ChatGPT UI model.
CHATGPT_DEFAULT_MODEL=
CHATGPT_MODEL_SWITCH_TIMEOUT=10000

# Timeouts (milliseconds)
RESPONSE_TIMEOUT=120000
SELECTOR_TIMEOUT=10000

# Attachment handling
ATTACHMENT_EXPAND_MULTIPAGE=true
ATTACHMENT_MAX_PAGES=24
ATTACHMENT_RENDER_DPI=144

# Human behavior simulation
TYPING_SPEED_MIN=50
TYPING_SPEED_MAX=150
THINKING_PAUSE_MIN=1000
THINKING_PAUSE_MAX=3000
POLL_INTERVAL_MS=500

# Logging
LOG_DIR=./logs
IMAGES_DIR=./downloads/images
AUDIO_DIR=./downloads/audio
LOG_LEVEL=DEBUG
VERBOSE=true

# API server
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT_SECONDS=5
API_TOKEN=dummy123
API_TOKEN_OPTIONAL=false

# OpenAI/Ollama compatibility features
API_THREAD_CONTRACT_MODE=false
API_THREAD_CONTRACT_TTL_SECONDS=3600
API_APP_THREAD_MODE=false
API_APP_THREAD_TTL_SECONDS=86400
API_HEADER_ROW_MERGE_MODE=false
OLLAMA_EMBEDDING_MODELS=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSIONS=768
OLLAMA_ACTIVE_MODEL_TTL_SECONDS=900

# VNC authentication (Docker/noVNC)
VNC_PASSWORD=catgpt
